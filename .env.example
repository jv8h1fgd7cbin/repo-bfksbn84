# Telegram MTProto (my.telegram.org)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION_NAME=pet_finder
# user_id администратора для уведомлений (Saved Messages, если равен id аккаунта)
ADMIN_USER_ID=0

# ИИ-провайдер: openai | anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Для Anthropic (в т.ч. совместимые прокси):
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pet_finder
POSTGRES_USER=pet_finder
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Лимиты и поведение
DAILY_NEW_USERS_LIMIT=100
HISTORY_BACKFILL_LIMIT=2000
MIN_MESSAGES_FOR_CATEGORY=2
CONTEXT_MESSAGES_COUNT=10
DIALOGS_REFRESH_SECONDS=300
# Чёрный список чатов (chat_id или username через запятую) — не мониторятся
EXCLUDED_CHATS=

# Защита от 429 у ИИ-провайдера
AI_MIN_INTERVAL_SECONDS=3.0
AI_RETRY_MAX_ATTEMPTS=5
AI_BACKOFF_BASE_SECONDS=30
AI_BATCH_SIZE=10
AI_BATCH_PAUSE_SECONDS=60

# Авто-поиск и авто-вступление в публичные группы (риск ограничений TG — лимиты ниже)
DISCOVERY_ENABLED=true
DISCOVERY_KEYWORDS=собаки,собака,собаководы,щенки,щенок,питомник собак,кинолог,дрессировка собак,кошки,кошка,котята,котёнок,кошатники,котолюбы,котомания,домашние животные,питомцы,питомец,зоомагазин,зоотовары,корм для животных,ветеринар,ветклиника,ветеринария,груминг,передержка,приют животных,приют для собак,приют для кошек,волонтёры животные,пристройство животных,лабрадор,овчарка,хаски,корги,шпиц,такса,чихуахуа,йорк,мопс,бульдог,мейн-кун,британская кошка,шотландская кошка,сфинкс,бенгальская кошка,вислоухие
DISCOVERY_INTERVAL_SECONDS=1800
MAX_JOINS_PER_DAY=20
JOIN_DELAY_MIN_SECONDS=180
JOIN_DELAY_MAX_SECONDS=300
RELEVANCE_SAMPLE_SIZE=40

# Админ-панель
ADMIN_PANEL_HOST=0.0.0.0
ADMIN_PANEL_PORT=8080
# Вход в панель через Telegram (кука сессии). Отключить только в закрытой сети.
ADMIN_AUTH_ENABLED=true
# Секрет для подписи куки входа (любая длинная строка). Пусто = вывод из api_hash.
ADMIN_SECRET=

LOG_LEVEL=INFO
