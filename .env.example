# Telegram MTProto (my.telegram.org)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION_NAME=pet_finder
# user_id администратора для уведомлений (Saved Messages, если равен id аккаунта)
ADMIN_USER_ID=0

# ИИ-провайдер: openai | anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Для Anthropic (в т.ч. совместимые прокси):
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pet_finder
POSTGRES_USER=pet_finder
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Лимиты и поведение
DAILY_NEW_USERS_LIMIT=100
HISTORY_BACKFILL_LIMIT=2000
MIN_MESSAGES_FOR_CATEGORY=2
CONTEXT_MESSAGES_COUNT=10
DIALOGS_REFRESH_SECONDS=300

# Админ-панель
ADMIN_PANEL_HOST=0.0.0.0
ADMIN_PANEL_PORT=8080

LOG_LEVEL=INFO
